rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Validation for GlobalSolve
    function isValidGlobalSolve(data) {
      return data.keys().hasAll(['userId', 'userName', 'timeMs', 'scramble', 'date']) &&
             data.keys().size() == 5 &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() <= 100 &&
             data.timeMs is number && data.timeMs > 0 &&
             data.scramble is string && data.scramble.size() <= 500 &&
             data.date is string; // Date is ISO string in blueprint
    }

    match /globalSolves/{solveId} {
      allow list: if true; // Public leaderboard
      allow get: if true;
      allow create: if isSignedIn() && isValidGlobalSolve(incoming());
      // No updates or deletes allowed for historical records
    }
  }
}
